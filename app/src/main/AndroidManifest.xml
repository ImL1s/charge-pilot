<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Special access permissions; all user-grantable. -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />

    <queries>
        <package android:name="moe.shizuku.privileged.api" />
        <package android:name="com.android.vending" />
        <package android:name="com.sec.android.app.samsungapps" />
        <package android:name="com.samsung.android.game.gamehome" />
        <package android:name="com.samsung.android.game.gametools" />
        <package android:name="com.samsung.android.game.gos" />
        <package android:name="com.samsung.android.goodlock" />
        <package android:name="com.samsung.android.game.gamelab" />
        <package android:name="com.samsung.android.game.gameboosterplus" />
    </queries>

    <application
        android:name=".ChargePilotApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChargePilot"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ChargePilot.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
