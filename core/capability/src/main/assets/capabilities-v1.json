{
  "schemaVersion": 1,
  "lastUpdated": "2026-05-11",
  "rules": [
    {
      "id": "samsung-galaxy-s2x-pause-pd",
      "matchers": {
        "manufacturer": "SAMSUNG",
        "modelRegex": "SM-S(91|92|93|94)[0-9].*",
        "minRomVersion": { "flavor": "ONE_UI", "version": "6.0" }
      },
      "capabilities": [
        {
          "id": "samsung-galaxy-s2x-pause-pd::PAUSE_PD_DURING_GAMING",
          "type": "PAUSE_PD_DURING_GAMING",
          "availableMethods": ["OFFICIAL_GUIDANCE", "WRITE_SETTINGS_KEY"],
          "settingsKey": { "namespace": "system", "key": "pass_through", "type": "int" },
          "officialIntent": {
            "action": "android.settings.SETTINGS",
            "fallbackPath": "Game Booster -> Pause USB PD charging when gaming"
          },
          "preconditions": [
            { "type": "PdChargerPresent" },
            { "type": "BatteryLevelAbove", "percent": 20 },
            { "type": "GameInForeground" }
          ],
          "evidence": "PROJECT_VERIFIED",
          "sourceUrl": "https://www.samsung.com/levant/support/mobile-devices/whats-the-pause-charging-via-pd-feature/",
          "verifiedDate": "2026-04-12"
        }
      ]
    },
    {
      "id": "samsung-galaxy-zfold-zflip",
      "matchers": {
        "manufacturer": "SAMSUNG",
        "modelRegex": "SM-F(7|9)[0-9]{2}.*",
        "minRomVersion": { "flavor": "ONE_UI", "version": "6.0" }
      },
      "capabilities": [
        {
          "id": "samsung-galaxy-zfold-zflip::PAUSE_PD_DURING_GAMING",
          "type": "PAUSE_PD_DURING_GAMING",
          "availableMethods": ["OFFICIAL_GUIDANCE"],
          "officialIntent": {
            "action": "android.settings.SETTINGS",
            "fallbackPath": "Game Booster -> Pause USB PD charging when gaming"
          },
          "evidence": "OFFICIAL_DOC",
          "sourceUrl": "https://www.samsung.com/"
        }
      ]
    },
    {
