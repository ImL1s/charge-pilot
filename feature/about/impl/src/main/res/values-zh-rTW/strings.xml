<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="about_title_app">Charge Pilot</string>
    <string name="about_body_app">跨品牌充電控制 App。在支援的手機上，可直接在 Charge Pilot 內切換旁路充電或充電上限，OEM 設定頁保留為備用路徑。</string>
    <string name="about_title_privacy">隱私與安全</string>
    <string name="about_body_privacy">沒有遙測、沒有雲端同步，也沒有背景特權操作。操作紀錄只儲存在此裝置本機。</string>
    <string name="about_step_manual_first">可用時一律優先使用 OEM 官方手動設定。</string>
    <string name="about_step_app_control_condition">只有在對應策略已安裝且可用時，才會顯示 App 內控制。</string>
    <string name="about_step_reversible">設定寫入可從首頁或 OEM 設定頁還原。</string>
    <string name="about_title_build_boundaries">版本邊界</string>
    <string name="about_body_build_boundaries">Play 版本保留非特權路徑與備用跳轉。Full 版本加入 Shizuku/root 模組，以支援封鎖一般寫入的 ROM；Samsung S24 Ultra 的 App 內控制使用 Shizuku，不需要 root。</string>
    <string name="about_title_license">授權</string>
    <string name="about_body_license">開源授權為 AGPL-3.0。品牌項目來自內建登錄檔，並在可用時包含證據標籤與驗證日期。</string>
    <string name="about_title_device_report">裝置報告</string>
    <string name="about_body_device_report">複製此手機的 Markdown 摘要，可貼到 GitHub 裝置支援議題。不會自動上傳。</string>
    <string name="about_copy_device_report">複製裝置報告</string>
    <string name="about_share_device_report">分享裝置報告</string>
    <string name="about_device_report_copied">已複製到剪貼簿</string>
</resources>
